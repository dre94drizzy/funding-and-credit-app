function commGetSession() {
  try {
    const s = sessionStorage.getItem('cpc_comm_session');
    if (!s) return null;
    const data = JSON.parse(s);
    // Session expires after 8 hours
    if (Date.now() > data.exp) { sessionStorage.removeItem('cpc_comm_session'); return null; }
    return data;
  } catch(e) { return null; }
}
function commSetSession(user) {
  const s = { username: user.username, uid: user.uid, isPremium: user.isPremium||false, exp: Date.now() + 8*60*60*1000 };
  sessionStorage.setItem('cpc_comm_session', JSON.stringify(s));
  COMM_USER = s;
}
function commClearSession() {
  sessionStorage.removeItem('cpc_comm_session');
  COMM_USER = null;
}

function commIsLoggedIn() {
  if (localStorage.getItem('cpc_admin_session')==='1') return true;
  const s = commGetSession();
  return !!s;
}

