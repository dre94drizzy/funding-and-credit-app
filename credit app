function commPasswordStrength(val) {
  const bar = document.getElementById('comm-pass-bar');
  const lbl = document.getElementById('comm-pass-label');
  if (!bar || !lbl) return;
  let score = 0;
  if (val.length >= 12) score++;
  if (val.length >= 16) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const levels = [{w:'20%',c:'#ef4444',t:'Too weak'},{w:'40%',c:'#f97316',t:'Weak'},{w:'60%',c:'#fbbf24',t:'Fair'},{w:'80%',c:'#34d399',t:'Good'},{w:'100%',c:'#10b981',t:'Strong'}];
  const lvl = levels[Math.min(score, 4)];
  bar.style.width = lvl.w; bar.style.background = lvl.c;
  lbl.textContent = lvl.t; lbl.style.color = lvl.c;
}

async function commLogin() {
  const user = (document.getElementById('comm-login-user')?.value||'').trim().toLowerCase();
  const pass = document.getElementById('comm-login-pass')?.value||'';
  const errEl = document.getElementById('comm-login-err');
  errEl.style.display = 'none';

  if (!user || !pass) { errEl.textContent = 'Please enter your username and password.'; errEl.style.display='block'; return; }

  // Rate limit check
  if (!commCheckRateLimit(user)) {
    const mins = commLockoutMinutes(user);
    errEl.textContent = `Too many failed attempts. Try again in ${mins} minute${mins!==1?'s':''}.`;
    errEl.style.display = 'block'; return;
  }

  const users = loadCommUsers();
  const account = users.find(u => u.username === user);
  if (!account) {
    commRecordAttempt(user, false);
    // Generic message — don't reveal whether username exists
    errEl.textContent = 'Incorrect username or password.';
    errEl.style.display = 'block'; return;
  }

  const hash = await hashStr(COMM_SALT + account.uid, pass);
  if (hash !== account.passHash) {
    commRecordAttempt(user, false);
    errEl.textContent = 'Incorrect username or password.';
    errEl.style.display = 'block'; return;
  }

  commRecordAttempt(user, true);
  commSetSession(account);
  document.getElementById('comm-login-user').value = '';
  document.getElementById('comm-login-pass').value = '';
  initCommunity();
}

async function commRegister() {
  const username = (document.getElementById('comm-reg-user')?.value||'').trim().toLowerCase();
  const email = (document.getElementById('comm-reg-email')?.value||'').trim().toLowerCase();
  const pass = document.getElementById('comm-reg-pass')?.value||'';
  const confirm = document.getElementById('comm-reg-confirm')?.value||'';
  const sq = document.getElementById('comm-reg-sq')?.value||'';
  const sa = (document.getElementById('comm-reg-sa')?.value||'').trim().toLowerCase();
  const code = (document.getElementById('comm-reg-code')?.value||'').trim().toUpperCase();
  const errEl = document.getElementById('comm-reg-err');
  const okEl = document.getElementById('comm-reg-ok');
  errEl.style.display = 'none'; okEl.style.display = 'none';

  // Validation
  if (!username || !email || !pass || !confirm || !sq || !sa || !code) {
    errEl.textContent = 'All fields are required, including security question and answer.'; errEl.style.display='block'; return;
  }
  if (!/^[a-z0-9_]{3,32}$/.test(username)) {
    errEl.textContent = 'Username must be 3–32 characters: letters, numbers, and underscores only.'; errEl.style.display='block'; return;
  }
  if (pass.length < 12) {
    errEl.textContent = 'Password must be at least 12 characters.'; errEl.style.display='block'; return;
  }
  if (pass !== confirm) {
    errEl.textContent = 'Passwords do not match.'; errEl.style.display='block'; return;
  }

  // Verify subscriber access code
  const whitelist = loadCommSubs();
  const subEntry = whitelist.find(e => {
    const entryCode = (typeof e==='object' ? e.pin : e)||'';
    return entryCode.toUpperCase() === code;
  });
  if (!subEntry) {
    errEl.textContent = 'Invalid access code. Subscribe on Fanbasis first, then contact Clear Pro for your code.';
    errEl.style.display='block'; return;
  }

  // Check username not already taken
  const users = loadCommUsers();
  if (users.find(u => u.username === username)) {
    errEl.textContent = 'Username is taken. Please choose another.'; errEl.style.display='block'; return;
  }
  if (users.find(u => u.email === email)) {
    errEl.textContent = 'An account with this email already exists. Try signing in.'; errEl.style.display='block'; return;
  }

  // Create account — UUID-based ID, hashed password and security answer
  const uid = 'u_' + crypto.randomUUID().replace(/-/g,'').slice(0,16);
  const passHash = await hashStr(COMM_SALT + uid, pass);
  const saHash = await hashStr(COMM_SALT + uid + 'sq', sa);
  const isPremium = loadPremiumSubs().some(e => typeof e==='object' ? e.email===email : false);
  const newUser = { uid, username, email, passHash, securityQuestion: sq, securityAnswerHash: saHash, isPremium, createdAt: Date.now() };
  users.push(newUser);
  saveCommUsers(users);

  okEl.textContent = '✅ Account created! Signing you in...';
  okEl.style.display = 'block';
  commSetSession(newUser);
  setTimeout(function(){ initCommunity(); }, 900);
}

