async function commLandingSignIn() {
  const user = (document.getElementById('cl-login-user')?.value||'').trim().toLowerCase();
  const pass = document.getElementById('cl-login-pass')?.value||'';
  const errEl = document.getElementById('cl-login-err');
  errEl.style.display = 'none';
  if (!user || !pass) { errEl.textContent = 'Please enter your username and password.'; errEl.style.display='block'; return; }
  if (!commCheckRateLimit(user)) {
    const mins = commLockoutMinutes(user);
    errEl.textContent = 'Too many failed attempts. Try again in ' + mins + ' minute' + (mins!==1?'s':'.'); errEl.style.display='block'; return;
  }
  const users = loadCommUsers();
  const account = users.find(u => u.username === user);
  if (!account) { commRecordAttempt(user, false); errEl.textContent = 'Incorrect username or password.'; errEl.style.display='block'; return; }
  const hash = await hashStr(COMM_SALT + account.uid, pass);
  if (hash !== account.passHash) { commRecordAttempt(user, false); errEl.textContent = 'Incorrect username or password.'; errEl.style.display='block'; return; }
  commRecordAttempt(user, true);
  commSetSession(account);
  document.getElementById('cl-login-user').value = '';
  document.getElementById('cl-login-pass').value = '';
  show('s-community');
}

