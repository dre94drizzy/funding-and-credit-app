const SITE_ATTEMPTS_KEY = 'cpc_site_attempts';

function siteCheckRate(identifier) {
  const key = SITE_ATTEMPTS_KEY + '_' + identifier.toLowerCase();
  const raw = localStorage.getItem(key);
  if (!raw) return true;
  const d = JSON.parse(raw);
  if (Date.now() > d.until) { localStorage.removeItem(key); return true; }
  return d.count < 5;
}
function siteRecordAttempt(identifier, success) {
  const key = SITE_ATTEMPTS_KEY + '_' + identifier.toLowerCase();
  if (success) { localStorage.removeItem(key); return; }
  const raw = localStorage.getItem(key);
  const d = raw ? JSON.parse(raw) : { count: 0, until: 0 };
  d.count++;
  // Exponential backoff: 2^attempts minutes, capped at 60 min
  const mins = Math.min(Math.pow(2, d.count), 60);
  d.until = Date.now() + mins * 60 * 1000;
  localStorage.setItem(key, JSON.stringify(d));
}
function siteLockoutMins(identifier) {
  const key = SITE_ATTEMPTS_KEY + '_' + identifier.toLowerCase();
  const raw = localStorage.getItem(key);
  if (!raw) return 0;
  const d = JSON.parse(raw);
  return Math.ceil((d.until - Date.now()) / 60000);
}

