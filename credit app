function sitePassStrength(val) {
  const bar = document.getElementById('site-pass-bar');
  const lbl = document.getElementById('site-pass-label');
  if (!bar || !lbl) return;
  let score = 0;
  if (val.length >= 12) score++;
  if (val.length >= 16) score++;
  if (/[A-Z]/.test(val)) score++;
  if (/[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const levels = [{w:'20%',c:'#ef4444',t:'Too weak'},{w:'40%',c:'#f97316',t:'Weak'},{w:'60%',c:'#fbbf24',t:'Fair'},{w:'80%',c:'#34d399',t:'Good'},{w:'100%',c:'#10b981',t:'Strong'}];
  const lvl = levels[Math.min(score, 4)];
  bar.style.width = lvl.w; bar.style.background = lvl.c;
  lbl.textContent = lvl.t; lbl.style.color = lvl.c;
}

async function siteLogin() {
  const userVal = (document.getElementById('site-login-user')?.value||'').trim().toLowerCase();
  const pass = document.getElementById('site-login-pass')?.value||'';
  const errEl = document.getElementById('site-login-err');
  errEl.style.display = 'none';
  if (!userVal || !pass) { errEl.textContent = 'Please enter your username/email and password.'; errEl.style.display='block'; return; }
  if (!siteCheckRate(userVal)) {
    const m = siteLockoutMins(userVal);
    errEl.textContent = 'Too many failed attempts. Try again in ' + m + ' minute' + (m!==1?'s':'.'); errEl.style.display='block'; return;
  }
  const users = loadSiteUsers();
  const account = users.find(u => u.username===userVal || u.email===userVal);
  if (!account) { siteRecordAttempt(userVal, false); errEl.textContent = 'Incorrect username or password.'; errEl.style.display='block'; return; }
  const hash = await hashStr(SITE_SALT + account.uid, pass);
  if (hash !== account.passHash) { siteRecordAttempt(userVal, false); errEl.textContent = 'Incorrect username or password.'; errEl.style.display='block'; return; }
  siteRecordAttempt(userVal, true);
  siteSetSession(account);
  document.getElementById('site-login-user').value = '';
  document.getElementById('site-login-pass').value = '';
  // Owner goes straight to staff dashboard
  if (account.isOwner) {
    localStorage.setItem('cpc_admin_session', '1');
    show('s-dashboard');
  } else {
