function commVerifyPremium() {
  const emailEl = document.getElementById('premium-verify-email');
  const pinEl = document.getElementById('premium-verify-pin');
  const msgEl = document.getElementById('premium-verify-msg');
  const email = (emailEl ? emailEl.value : '').trim().toLowerCase();
  const pin = (pinEl ? pinEl.value : '').trim().toUpperCase();
  if (!email || !pin) {
    msgEl.textContent = 'Please enter your email and premium access code.';
    msgEl.style.display = 'block'; msgEl.style.background = 'rgba(239,68,68,.1)'; msgEl.style.color = '#f87171'; return;
  }
  const whitelist = loadPremiumSubs();
  const entry = whitelist.find(e => typeof e==='object' ? e.email===email : e===email);
  if (entry && (typeof entry==='string' || entry.pin===pin)) {
    // Mark user account as premium if they are logged in
    const session = commGetSession();
    if (session) {
      const users = loadCommUsers();
      const account = users.find(u => u.uid === session.uid);
      if (account) { account.isPremium = true; saveCommUsers(users); session.isPremium = true; commSetSession(account); }
    }
    msgEl.textContent = 'Premium access granted! Welcome.';
    msgEl.style.display = 'block'; msgEl.style.background = 'rgba(251,191,36,.1)'; msgEl.style.color = '#fbbf24';
