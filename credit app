  const okEl = document.getElementById('site-reg-ok');
  errEl.style.display='none'; okEl.style.display='none';
  if (!name||!email||!username||!pass||!confirm||!sq||!sa) { errEl.textContent='All fields required, including security question and answer.'; errEl.style.display='block'; return; }
  if (!/^[a-z0-9_]{3,32}$/.test(username)) { errEl.textContent='Username: 3–32 chars, letters/numbers/underscores only.'; errEl.style.display='block'; return; }
  if (pass.length < 12) { errEl.textContent='Password must be at least 12 characters.'; errEl.style.display='block'; return; }
  if (WEAK_PASSWORDS.includes(pass.toLowerCase())) { errEl.textContent='That password is too common. Please choose something stronger.'; errEl.style.display='block'; return; }
  if (pass !== confirm) { errEl.textContent='Passwords do not match.'; errEl.style.display='block'; return; }
