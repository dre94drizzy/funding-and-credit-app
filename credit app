function adminGrantPremium(email, pin) {
  if (!email) return;
  const clean = email.trim().toLowerCase();
  const accessPin = (pin||'').trim().toUpperCase() || Math.random().toString(36).slice(2,8).toUpperCase();
  const whitelist = loadPremiumSubs();
