function submitApp() {
  // ── Collect all current field values ──────────────────────────
  saveStep1();
  saveStep2();

  const hasBiz = applyData.products.some(p => ['mca','biz_loc','biz_card'].includes(p));
  const hasPersonal = applyData.products.some(p => p === 'personal_loan');
  const missing = [];

  // Products
  if (!applyData.products.length) missing.push('Product selection (Step 1)');

  // Personal Info
  if (!applyData.firstName.trim()) missing.push('First Name');
  if (!applyData.lastName.trim()) missing.push('Last Name');
  if (!applyData.email.trim()) missing.push('Email Address');
  if (!applyData.phone.trim()) missing.push('Phone Number');
  if (!applyData.dob.trim()) missing.push('Date of Birth');
  if (!applyData.ssn.trim() || applyData.ssn.length < 4) missing.push('SSN Last 4 Digits');
  if (!applyData.address.trim()) missing.push('Street Address');
  if (!applyData.city.trim()) missing.push('City');
  if (!applyData.state.trim()) missing.push('State');
  if (!applyData.zip.trim() || applyData.zip.length < 5) missing.push('ZIP Code');
  if (!applyData.housingPayment.trim()) missing.push('Monthly Housing Payment');
  if (!applyData.timeAtAddress) missing.push('Time at Current Address');

  // Financial Info
  if (!applyData.employment) missing.push('Employment Status');
  if (!applyData.income.trim()) missing.push('Annual Income');
  if (!applyData.monthlyDebt.trim()) missing.push('Monthly Debt Payments');
  if (!applyData.creditScore) missing.push('Credit Score Range');

  // Conditional fields
  if (hasPersonal && !applyData.loanAmount.trim()) missing.push('Loan Amount Requested');
  if (hasPersonal && !applyData.loanPurpose) missing.push('Loan Purpose');
  if (hasBiz && !applyData.bizName.trim()) missing.push('Business Name');
  if (hasBiz && !applyData.bizType) missing.push('Business Type');
  if (hasBiz && !applyData.bizStarted) missing.push('Time in Business');
  if (hasBiz && !applyData.monthlyRevenue.trim()) missing.push('Monthly Revenue');

  // Show error if anything missing
  if (missing.length > 0) {
    // Show error inside the body panel
    let errEl = document.getElementById('apply-submit-err');
    if (!errEl) {
      errEl = document.createElement('div');
      errEl.id = 'apply-submit-err';
      errEl.style.cssText = 'padding:12px 14px;border-radius:10px;background:rgba(239,68,68,.09);border:1px solid rgba(239,68,68,.3);font-size:12px;color:#f87171;margin-bottom:12px;line-height:1.8';
      const body = document.getElementById('apply-body');
      if (body) body.insertBefore(errEl, body.firstChild);
    }
    errEl.innerHTML = '<strong>Please complete all required fields before submitting:</strong><br>' +
      missing.map(f => '&bull; ' + f).join('<br>');
    errEl.style.display = 'block';
    window.scrollTo(0, 0);
    return;
  }

  // All good — submit
  const app = {...applyData, id:'app_'+Date.now(), ts:Date.now(), type:'pre_approval', status:'pending', adminNote:''};
  DB.apps.push(app);
  DB.save('apps');
  show('s-done');
}

