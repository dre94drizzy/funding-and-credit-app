const SUB_SALT = 'cpc_sub_salt_v1';
function loadSubUsers() { try { return JSON.parse(localStorage.getItem('cpc_sub_users')||'[]'); } catch(e){ return []; } }
function saveSubUsers(u) { try { localStorage.setItem('cpc_sub_users', JSON.stringify(u)); } catch(e){} }

async function createSubUser() {
  const name     = (document.getElementById('su-name')?.value||'').trim();
  const username = (document.getElementById('su-username')?.value||'').trim().toLowerCase();
  const pass     = document.getElementById('su-pass')?.value||'';
  const role     = (document.getElementById('su-role')?.value||'').trim();
  const err      = document.getElementById('su-err');
  err.style.display='none';
  if (!name||!username||!pass||!role) { err.textContent='All fields required.'; err.style.display='block'; return; }
  if (!/^[a-z0-9_]{3,32}$/.test(username)) { err.textContent='Username: 3–32 chars, letters/numbers/underscores only.'; err.style.display='block'; return; }
  if (pass.length < 8) { err.textContent='Password must be at least 8 characters.'; err.style.display='block'; return; }
  if (username === ADMIN_USERNAME) { err.textContent='That username is reserved.'; err.style.display='block'; return; }
  const users = loadSubUsers();
  if (users.find(u=>u.username===username)) { err.textContent='Username already taken.'; err.style.display='block'; return; }
  const uid = 'sub_'+crypto.randomUUID().replace(/-/g,'').slice(0,14);
  const passHash = await hashStr(SUB_SALT+uid, pass);
  users.push({ uid, name, username, passHash, role, createdAt:Date.now(), active:true });
  saveSubUsers(users);
  document.getElementById('su-name').value='';
  document.getElementById('su-username').value='';
  document.getElementById('su-pass').value='';
  document.getElementById('su-role').value='';
  document.getElementById('staff-add-wrap').style.display='none';
  renderSubUsers();
}

