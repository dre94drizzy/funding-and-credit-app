  if (users.find(u=>u.email===email)) { errEl.textContent='An account with this email already exists. Try signing in.'; errEl.style.display='block'; return; }
  const uid = 'su_' + crypto.randomUUID().replace(/-/g,'').slice(0,16);
  const passHash = await hashStr(SITE_SALT + uid, pass);
  const saHash = await hashStr(SITE_SALT + uid + 'sq', sa);
