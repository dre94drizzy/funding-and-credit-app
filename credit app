async function siteRecoveryReset() {
  const newpass = document.getElementById('site-rec-newpass')?.value||'';
  const confirm = document.getElementById('site-rec-confirm')?.value||'';
  const err = document.getElementById('site-rec-err3');
  err.style.display='none';
  if (!newpass || !confirm) { err.textContent='Please fill in both password fields.'; err.style.display='block'; return; }
  if (newpass.length < 12) { err.textContent='Password must be at least 12 characters.'; err.style.display='block'; return; }
  if (WEAK_PASSWORDS.includes(newpass.toLowerCase())) { err.textContent='That password is too common. Choose something stronger.'; err.style.display='block'; return; }
  if (newpass !== confirm) { err.textContent='Passwords do not match.'; err.style.display='block'; return; }
  if (!_siteRecUser) { err.textContent='Session expired. Please start over.'; err.style.display='block'; return; }
  const users = loadSiteUsers();
  const idx = users.findIndex(u => u.uid === _siteRecUser.uid);
  if (idx < 0) { err.textContent='Account not found. Contact support.'; err.style.display='block'; return; }
  users[idx].passHash = await hashStr(SITE_SALT + _siteRecUser.uid, newpass);
  saveSiteUsers(users);
  _siteRecUser = null;
  document.getElementById('site-recovery-wrap').style.display='none';
  alert('✅ Password reset successfully! You can now sign in with your new password.');
}

