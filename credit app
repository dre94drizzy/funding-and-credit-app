// Rate limiting
function commCheckRateLimit(username) {
  const key = LOGIN_ATTEMPT_KEY + '_' + username.toLowerCase();
  const raw = localStorage.getItem(key);
  if (!raw) return true;
  const data = JSON.parse(raw);
  if (Date.now() > data.until) { localStorage.removeItem(key); return true; }
  return data.count < MAX_ATTEMPTS;
}
function commRecordAttempt(username, success) {
  const key = LOGIN_ATTEMPT_KEY + '_' + username.toLowerCase();
  if (success) { localStorage.removeItem(key); return; }
  const raw = localStorage.getItem(key);
  const data = raw ? JSON.parse(raw) : { count: 0, until: Date.now() + LOCKOUT_MS };
  data.count++;
  if (data.count >= MAX_ATTEMPTS) data.until = Date.now() + LOCKOUT_MS;
  localStorage.setItem(key, JSON.stringify(data));
}
function commLockoutMinutes(username) {
  const key = LOGIN_ATTEMPT_KEY + '_' + username.toLowerCase();
  const raw = localStorage.getItem(key);
  if (!raw) return 0;
  const data = JSON.parse(raw);
  return Math.ceil((data.until - Date.now()) / 60000);
}

