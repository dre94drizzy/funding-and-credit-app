<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#060910;--surface:#0d1117;--surface2:#111827;--border:rgba(255,255,255,.08);--border2:rgba(255,255,255,.05);--text:#f0f6ff;--muted:#64748b;--green:#10b981;--amber:#f59e0b;--red:#ef4444}
body{background:var(--bg);color:var(--text);font-family:'Instrument Sans',sans-serif;line-height:1.7;font-size:16px}
h1,h2,h3{font-family:'Cabinet Grotesk',sans-serif}
.btn{padding:11px 22px;border-radius:10px;background:linear-gradient(135deg,#1a1a1a,#383838);color:#fff;font-size:14px;font-weight:700;cursor:pointer;font-family:'Instrument Sans',sans-serif;transition:all .2s;display:inline-flex;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.12)}
.btn:hover{background:linear-gradient(135deg,#2a2a2a,#484848);transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,0,0,.4)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.btn-white{background:linear-gradient(135deg,#ffffff,#e2e8f0)!important;color:#000!important}
.btn-sm{padding:8px 16px!important;font-size:13px!important;border-radius:8px!important}
.btn-green{background:linear-gradient(135deg,#059669,#10b981)!important;border-color:rgba(16,185,129,.3)!important}
.btn-red{background:linear-gradient(135deg,#dc2626,#ef4444)!important;border-color:rgba(239,68,68,.3)!important}
.btn-teal{background:linear-gradient(135deg,#0f766e,#14b8a6)!important;border-color:rgba(20,184,166,.35)!important}
.btn-blue{background:linear-gradient(135deg,#1d4ed8,#3b82f6)!important;border-color:rgba(59,130,246,.35)!important}
.btn-purple{background:linear-gradient(135deg,#7c3aed,#a855f7)!important;border-color:rgba(168,85,247,.35)!important}
.btn-orange{background:linear-gradient(135deg,#92400e,#d97706)!important;border-color:rgba(217,119,6,.4)!important}
.inp{width:100%;padding:12px 15px;border-radius:10px;border:1.5px solid var(--border);background:rgba(255,255,255,.04);color:var(--text);font-size:15px;outline:none;transition:all .2s;font-family:'Instrument Sans',sans-serif}
.inp:focus{border-color:rgba(255,255,255,.3);background:rgba(255,255,255,.06)}
.inp option{background:#111}
.card{background:var(--surface);border-radius:14px;border:1px solid var(--border);padding:20px}
.badge{display:inline-flex;align-items:center;gap:5px;padding:5px 14px;background:rgba(255,255,255,.07);border-radius:20px;border:1px solid rgba(255,255,255,.12);font-size:12px;color:#e2e8f0;font-weight:600;letter-spacing:.4px;text-transform:uppercase}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
.fade-up{animation:fadeUp .35s ease both}
.spin{animation:spin .7s linear infinite}
.screen{display:none;min-height:100vh}
.screen.active{display:block}
nav.main-nav{padding:13px 24px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);background:rgba(6,9,16,.97);backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;flex-wrap:wrap;gap:8px}
.nav-logo{font-family:'Cabinet Grotesk',sans-serif;font-weight:900;font-size:20px;letter-spacing:-.3px}
.stat-card{background:var(--surface);border-radius:12px;border:1px solid var(--border);padding:14px;text-align:center}
.stat-num{font-family:'Cabinet Grotesk',sans-serif;font-size:26px;font-weight:900}
.stat-lbl{font-size:12px;color:var(--muted);margin-top:2px;text-transform:uppercase;letter-spacing:.4px}
.tab-bar{background:var(--surface);border-bottom:1px solid var(--border);display:flex;overflow-x:auto}
.tab-btn{padding:13px 18px;background:none;border:none;border-bottom:2px solid transparent;color:var(--muted);font-weight:500;font-size:13px;cursor:pointer;white-space:nowrap;font-family:'Instrument Sans',sans-serif;transition:all .2s}
.tab-btn.active{border-bottom-color:#14b8a6;color:#14b8a6;font-weight:700}
.tab-btn:disabled{opacity:.3;cursor:not-allowed}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.75);backdrop-filter:blur(6px);z-index:500;display:flex;align-items:flex-start;justify-content:center;padding:20px;overflow-y:auto}
.side-panel{position:fixed;top:0;right:0;bottom:0;width:min(420px,100vw);background:var(--surface);border-left:1px solid var(--border);overflow-y:auto;z-index:400;padding:22px}
.lbl{font-size:11px;color:var(--muted);font-weight:600;display:block;margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.sc-green{color:#34d399}.sc-blue{color:#60a5fa}.sc-amber{color:#fbbf24}.sc-orange{color:#f97316}.sc-red{color:#f87171}
.form-group{margin-bottom:14px}
.form-group label{display:block;font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:5px}
.audit-entry{display:flex;gap:10px;padding:8px 0;border-bottom:1px solid var(--border2)}
.audit-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:4px}
.paywall-wrap{min-height:75vh;display:flex;align-items:center;justify-content:center;padding:32px 18px}
.paywall-card{background:var(--surface);border-radius:20px;border:1px solid rgba(192,132,252,.3);padding:36px 28px;text-align:center;max-width:500px;width:100%}
.join-btn{width:100%;padding:14px;border-radius:11px;background:linear-gradient(135deg,#7c3aed,#a855f7);border:none;color:#fff;font-size:15px;font-weight:700;cursor:pointer;font-family:'Cabinet Grotesk',sans-serif;transition:opacity .2s}
.join-btn:hover{opacity:.88}
.comm-grid{display:grid;grid-template-columns:1fr 270px;gap:18px;max-width:1080px;margin:0 auto;padding:20px 18px}
@media(max-width:720px){.comm-grid{grid-template-columns:1fr}}
@media(max-width:640px){.cr-grid{grid-template-columns:1fr!important}}
.comm-post{padding:14px 0;border-bottom:1px solid var(--border2)}
.comm-post:last-child{border-bottom:none}
.ph{display:flex;gap:10px;align-items:flex-start;margin-bottom:8px}
.av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;font-family:'Cabinet Grotesk',sans-serif}
.pb{font-size:13px;color:rgba(255,255,255,.72);line-height:1.65;margin-bottom:8px}
.ptag{font-size:10px;padding:2px 8px;border-radius:10px;font-weight:700;display:inline-block;margin-right:5px}
.pact{display:flex;gap:12px;margin-top:8px}
.pa{background:none;border:none;color:var(--muted);font-size:11px;cursor:pointer;font-family:'Instrument Sans',sans-serif;padding:0;transition:color .2s}
.pa:hover{color:var(--text)}
.np-ta{flex:1;padding:10px 14px;border-radius:10px;border:1.5px solid var(--border);background:rgba(255,255,255,.04);color:var(--text);font-size:13px;font-family:'Instrument Sans',sans-serif;resize:none;outline:none;transition:border .2s}
.np-ta:focus{border-color:rgba(192,132,252,.4)}
.res-card{background:rgba(255,255,255,.03);border-radius:11px;border:1px solid var(--border2);padding:14px 16px;margin-bottom:10px}
.res-title{font-family:'Cabinet Grotesk',sans-serif;font-weight:800;font-size:16px;margin-bottom:6px}
.res-body{font-size:14px;color:rgba(255,255,255,.68);line-height:1.75}
.sm-box{background:rgba(255,255,255,.04);border-radius:9px;border:1px solid var(--border2);padding:10px;text-align:center}
.sm-num{font-family:'Cabinet Grotesk',sans-serif;font-size:22px;font-weight:900}
.sm-lbl{font-size:10px;color:var(--muted);margin-top:2px;text-transform:uppercase;letter-spacing:.3px}
.scat{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;border-radius:8px;cursor:pointer;font-size:13px;transition:background .2s}
.scat:hover{background:rgba(255,255,255,.04)}
.scat.active-cat{background:rgba(192,132,252,.08);color:#c084fc}
.scount{font-size:10px;padding:1px 7px;border-radius:10px;background:rgba(255,255,255,.06);color:var(--muted)}
.mrow{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--border2);font-size:12px}
.mrow:last-child{border-bottom:none}
.mbadge{font-size:10px;padding:1px 7px;border-radius:10px}
.sec-div{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.sec-label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
.sec-line{flex:1;height:1px;background:var(--border2)}
.sec-link{font-size:10px;color:#c084fc;background:none;border:none;cursor:pointer;font-family:'Instrument Sans',sans-serif;white-space:nowrap}
.comm-new-post{display:flex;gap:10px;align-items:flex-start;margin-bottom:16px}
.premium-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:10px;background:linear-gradient(135deg,rgba(251,191,36,.2),rgba(245,158,11,.1));border:1px solid rgba(251,191,36,.4);color:#fbbf24;font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:.6px}
.premium-card{cursor:pointer;border-color:rgba(251,191,36,.3)!important;background:linear-gradient(135deg,rgba(251,191,36,.07),rgba(245,158,11,.03))!important;position:relative;overflow:hidden;transition:all .2s}
.premium-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,#f59e0b,#fbbf24,#f59e0b)}
.premium-card:hover{transform:translateY(-2px);border-color:rgba(251,191,36,.6)!important}
.premium-gate{background:linear-gradient(135deg,rgba(251,191,36,.1),rgba(245,158,11,.05));border:1px solid rgba(251,191,36,.3);border-radius:14px;padding:28px;text-align:center;margin-bottom:20px}
.disclaimer-box{padding:14px 16px;border-radius:10px;background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);margin-bottom:20px;font-size:13px;color:rgba(255,255,255,.68);line-height:1.75}
.disclaimer-box strong{color:#f87171}
.resource-link{display:inline-flex;align-items:center;gap:4px;padding:5px 11px;border-radius:7px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);text-decoration:none;font-size:11px;font-weight:700;transition:all .2s}
.resource-link:hover{background:rgba(255,255,255,.09)}
/* ── CONTENT PROTECTION ───────────────────────────────────── */
.comm-protected{-webkit-user-select:none;-moz-user-select:none;-ms-user-select:none;user-select:none}
.comm-watermark{position:relative;overflow:hidden}
.comm-watermark::after{content:attr(data-user);position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:rgba(255,255,255,.04);transform:rotate(-25deg);letter-spacing:2px;text-transform:uppercase;pointer-events:none;white-space:nowrap;font-family:'Cabinet Grotesk',sans-serif;background:repeating-linear-gradient(-25deg,transparent,transparent 80px,rgba(255,255,255,.018) 80px,rgba(255,255,255,.018) 81px)}
#ss-shield{display:none;position:fixed;inset:0;z-index:99999;background:rgba(0,0,0,.97);align-items:center;justify-content:center;flex-direction:column;gap:16px;text-align:center;padding:40px}
@media print{#s-community,.comm-protected,.comm-watermark{display:none!important}body::before{content:'This content is protected. Printing is not permitted.';display:block;font-size:24px;text-align:center;padding:100px;color:#333}}
</style>
</head>
