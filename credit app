async function siteRecoveryStep2() {
  const answer = (document.getElementById('site-rec-answer')?.value||'').trim().toLowerCase();
  const err = document.getElementById('site-rec-err2');
  err.style.display='none';
  if (!answer) { err.textContent='Please enter your security answer.'; err.style.display='block'; return; }
  if (!_siteRecUser) { err.textContent='Session expired. Please start over.'; err.style.display='block'; return; }
  const hash = await hashStr(SITE_SALT + _siteRecUser.uid + 'sq', answer);
  if (hash !== _siteRecUser.securityAnswerHash) {
    err.textContent = 'Incorrect answer. Please try again.'; err.style.display='block'; return;
  }
  document.getElementById('site-rec-step2').style.display='none';
  document.getElementById('site-rec-step3').style.display='block';
