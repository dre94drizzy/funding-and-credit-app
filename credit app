function vaultCopy(key, btn) {
  const letter = VAULT_LETTERS[key];
  if (!letter) return;
  navigator.clipboard.writeText(letter.body).catch(()=>{});
  if (btn) { const orig=btn.textContent; btn.textContent='✅ Copied!'; setTimeout(()=>btn.textContent=orig, 2000); }
}

function vaultPrint(key) {
  const letter = VAULT_LETTERS[key];
  if (!letter) return;
  const win = window.open('','_blank');
  if (!win) return;
  const scriptTag = '<scr' + 'ipt>window.onload=function(){window.print()}<\/scr' + 'ipt>';
  win.document.write('<!DOCTYPE html><html><head><title>' + letter.title + '</title><style>body{font-family:Times New Roman,serif;font-size:12pt;padding:1in;line-height:1.9}pre{white-space:pre-wrap;font-family:inherit}@media print{@page{margin:.75in}}</style></head><body><h2>' + letter.title + '</h2><pre>' + letter.body + '</pre>' + scriptTag + '</body></html>');
  win.document.close();
}

