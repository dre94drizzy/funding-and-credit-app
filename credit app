function siteRecoveryStep1() {
  const val = (document.getElementById('site-rec-user')?.value||'').trim().toLowerCase();
  const err = document.getElementById('site-rec-err1');
  err.style.display='none';
  if (!val) { err.textContent='Please enter your username or email.'; err.style.display='block'; return; }
