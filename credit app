// ═══════════════════════════════════════════════════════════════
// CONTENT PROTECTION — COMMUNITY
// ═══════════════════════════════════════════════════════════════
(function() {
  const shield = document.getElementById('ss-shield');

  function showShield() {
    if (!shield) return;
    shield.style.display = 'flex';
    setTimeout(() => { shield.style.display = 'none'; }, 2500);
  }

  function inCommunity() {
    const comm = document.getElementById('s-community');
    return comm && comm.classList.contains('active');
  }

  // Detect screenshot key combos (best effort — not foolproof)
  document.addEventListener('keydown', function(e) {
    if (!inCommunity()) return;
    const mac = e.metaKey;
    const win = e.ctrlKey;
    const key = e.key;
    // Mac: Cmd+Shift+3, Cmd+Shift+4, Cmd+Shift+5, Cmd+Ctrl+Shift+3/4
    if (mac && e.shiftKey && ['3','4','5'].includes(key)) { e.preventDefault(); showShield(); }
    // Windows: PrtScn, Win+PrtScn, Alt+PrtScn
    if (key === 'PrintScreen') { e.preventDefault(); showShield(); }
    // Ctrl+P (print)
    if ((win || mac) && key === 'p') { e.preventDefault(); showShield(); }
    // Ctrl+S (save)
    if ((win || mac) && key === 's') { e.preventDefault(); }
    // Ctrl+U (view source)
    if (win && key === 'u') { e.preventDefault(); }
  });

  // Disable right-click in community
  document.addEventListener('contextmenu', function(e) {
    if (!inCommunity()) return;
    e.preventDefault();
  });

  // Visibility change — blur when tab switches (captures on other device)
  document.addEventListener('visibilitychange', function() {
    if (!inCommunity()) return;
    if (document.visibilityState === 'hidden') {
      // Blur community content momentarily
      const feed = document.getElementById('comm-feed');
      if (feed) { feed.style.filter = 'blur(20px)'; }
    } else {
      setTimeout(() => {
        const feed = document.getElementById('comm-feed');
        if (feed) { feed.style.filter = ''; }
      }, 400);
    }
  });
})();

function applyCommProtection() {
  // Get current logged-in username for watermark
  const session = (() => { try { const s = sessionStorage.getItem('cpc_comm_session'); return s ? JSON.parse(s) : null; } catch(e){ return null; } })();
  const username = session ? (session.username || 'member') : 'member';
  // Apply user-select:none and watermark to all community content panels
  const panels = document.querySelectorAll('[id^="comm-detail-"], [id^="comm-premium-"], #comm-feed');
  panels.forEach(el => {
    el.classList.add('comm-protected', 'comm-watermark');
    el.setAttribute('data-user', username + ' • clearproconsultant.com');
  });
}

// INIT
show('s-home');
</script>
