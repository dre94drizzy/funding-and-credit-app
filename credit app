const COMM_SALT = 'cpc_comm_salt_v2';
const LOGIN_ATTEMPT_KEY = 'cpc_login_attempts';
const MAX_ATTEMPTS = 5;
const LOCKOUT_MS = 15 * 60 * 1000; // 15 minutes

function loadCommUsers() { try { return JSON.parse(localStorage.getItem('cpc_comm_users')||'[]'); } catch(e){ return []; } }
function saveCommUsers(u) { try { localStorage.setItem('cpc_comm_users',JSON.stringify(u)); } catch(e){} }
